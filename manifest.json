{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.1.0",
  "description": "__MSG_appDesc__",
  "default_locale": "tr",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.sahibinden.com/*",
    "https://www.hepsiemlak.com/*",
    "https://www.emlakjet.com/*"
  ],
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "48": "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.sahibinden.com/ilan/*",
        "https://www.hepsiemlak.com/*",
        "https://www.emlakjet.com/*"
      ],
      "js": [
        "src/providers/registry.js",
        "src/providers/jsonld.js",
        "src/providers/sahibinden.js",
        "src/providers/hepsiemlak.js",
        "src/providers/emlakjet.js",
        "src/content/capture.js",
        "src/content/inject.js"
      ],
      "css": ["src/content/inject.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/dashboard/dashboard.html",
  "options_ui": {
    "page": "src/dashboard/dashboard.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "src/icons/icon16.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  }
}
